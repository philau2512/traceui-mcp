{
  "name": "traceui-mcp",
  "version": "0.2.1",
  "description": "Static analysis for React/Next.js — MCP server for AI agents to understand frontend code without running it",
  "type": "module",
  "bin": {
    "traceui": "./dist/cli.js",
    "traceui-mcp": "./dist/mcp/index.js"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "cli": "node dist/cli.js",
    "mcp": "node dist/mcp/index.js",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "npm run build && npm run test:run"
  },
  "keywords": [
    "react",
    "static-analysis",
    "mcp",
    "model-context-protocol",
    "ai",
    "parser",
    "typescript",
    "nextjs",
    "component-analysis",
    "ast"
  ],
  "author": "philau2512",
  "license": "MIT",
  "homepage": "https://github.com/philau2512/traceui-mcp#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/philau2512/traceui-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/philau2512/traceui-mcp/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "commander": "^12.0.0",
    "ts-morph": "^28.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^20.19.39",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "typescript": "^5.3.0",
    "vitest": "^2.0.0"
  }
}
